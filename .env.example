DATABASE_URL="sqlserver://server:1433;database=database_name;user=username;password=password;encrypt=true;trustServerCertificate=true"
PORT=3000

# Auth Service (for secret-key and service ticket verification)
AUTH_SERVICE_URL=http://iamauth.runasp.net
AUTH_VERIFY_PATH=/api/ticket/verify

# Set to true to disable auth for testing
# DISABLE_AUTH=true

# Zoom API Configuration (optional - leave empty to disable Zoom integration)
# ZOOM_CLIENT_ID="your-zoom-client-id"
# ZOOM_CLIENT_SECRET="your-zoom-client-secret"
# ZOOM_ACCOUNT_ID="your-zoom-account-id"  # Required for Account-level OAuth (recommended)
# ZOOM_USER_ID="me"  # Optional, defaults to "me" (account owner)
# ZOOM_API_KEY="your-legacy-api-key"      # Legacy JWT support
# ZOOM_API_SECRET="your-legacy-api-secret"
